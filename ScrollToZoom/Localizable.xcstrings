    "wants-dictatorship-message" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies kann zu leichten Verzögerungen beim Zoomen führen und den Stromverbrauch erhöhen. Wenn du keine anderen Tools verwendest, kannst du diese Option bedenkenlos deaktivieren."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This may cause slight delays when zooming and increase power consumption. If you don’t use other tools, you can safely disable it."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto puede causar ligeros retrasos al usar el zoom y aumentar el consumo de energía. Si no usas otras herramientas, puedes desactivar esta opción sin problema."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela peut entraîner de légers retards lors du zoom et augmenter la consommation d’énergie. Si vous n’utilisez pas d’autres outils, vous pouvez désactiver cette option sans risque."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",

    "permission-warning" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Scroll to Zoom aktiviert ist, kann das Entfernen der Berechtigung dazu führen, dass der Computer nicht mehr reagiert."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "When the scroll-to-zoom is enabled, removing permission may cause the computer to become unresponsive."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cuando el zoom con desplazamiento está activado, retirar el permiso puede hacer que el ordenador deje de responder."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lorsque le zoom par défilement est activé, retirer l’autorisation peut empêcher l’ordinateur de répondre."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "スクロールでズームする機能が有効なときにアクセス権を削除すると、コンピュータが応答しなくなる場合があります。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если масштабирование прокруткой включено, отзыв разрешения может привести к тому, что компьютер перестанет отвечать."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "当滚动来缩放功能启用时，移除权限可能会导致电脑不能响应。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "當捲動來縮放功能啟用時，移除權限可能會導致電腦不能回應。"
          }
        }
      }
    },

    "magic-zoom-message" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippe zweimal mit einem Finger und halte den Finger auf der Oberfläche, scrolle dann zum Zoomen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Double-tap with one finger and hold, then scroll to zoom."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toca dos veces con un dedo y mantenlo apoyado; después desplázate para hacer zoom."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Touchez deux fois avec un doigt et maintenez le contact, puis faites défiler pour zoomer."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "1本指でダブルタップしてそのまま触れ続け、スクロールしてズームします。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дважды коснитесь одним пальцем и удерживайте его, затем прокрутите для масштабирования."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "单指轻点两下并保持，然后滚动来缩放。"
          }
        },

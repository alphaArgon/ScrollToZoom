    "permission-message" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Öffne die „Systemeinstellungen“ und erlaube dieser App, den Computer zu steuern. Wenn der Eintrag für diese App bereits in der Liste angezeigt und aktiviert ist, entferne ihn und versuche es erneut."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Allow this application to control the computer in System Settings. If the item for this application is already listed and turned on, remove it and retry."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En «Ajustes del Sistema», permite que esta app controle el ordenador. Si el elemento de esta app ya aparece en la lista y está activado, elimínalo e inténtalo de nuevo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dans « Réglages Système », autorisez cette app à contrôler l’ordinateur. Si l’élément de cette app apparaît déjà dans la liste et qu’il est activé, supprimez-le, puis réessayez."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "「システム設定」で、このアプリケーションによる制御を許可してください。このアプリの項目が既にリストに表示され、有効になっている場合は、削除してからやり直してください。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "В «Системных настройках» разрешите этому приложению управлять компьютером. Если элемент этого приложения уже есть в списке и включен, удалите его и повторите попытку."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在 “系统设置” 中允许此应用程序控制电脑。如果此应用程序项已在列表中启用，将其移除后重试。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "在「系統設定」中允許此應用程式控制電腦。如果此應用程式項已在列表中啟用，將其移除後再試一次。"
          }
        }
      }
    },
    "permission-title" : {
      "localizations" : {
